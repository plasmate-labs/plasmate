{
  "name": "plasmate",
  "version": "0.4.0",
  "description": "Browser engine for AI agents. 10-100x fewer tokens than raw HTML. Web scraping with structured output for LLMs, RAG, and autonomous agents. Puppeteer/CDP compatible.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "browser",
    "headless",
    "web-scraping",
    "ai",
    "llm",
    "agent",
    "mcp",
    "langchain",
    "llamaindex",
    "rag",
    "puppeteer",
    "playwright",
    "token-optimization",
    "gpt",
    "claude",
    "vercel-ai",
    "crawling",
    "automation"
  ],
  "author": "Plasmate Labs",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/plasmate-labs/plasmate"
  },
  "homepage": "https://plasmate.app",
  "mcpName": "io.github.plasmate-labs/plasmate",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.4.0"
  }
}
