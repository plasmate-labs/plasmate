{
  "som_version": "1.0",
  "url": "https://example.com/settings",
  "title": "Settings",
  "lang": "en",
  "meta": {
    "html_bytes": 1200,
    "som_bytes": 300,
    "element_count": 6,
    "interactive_count": 6
  },
  "regions": [
    {
      "id": "r_settings",
      "role": "form",
      "label": "Settings form",
      "elements": [
        {
          "id": "e_email",
          "role": "text_input",
          "label": "Work email",
          "actions": ["type"],
          "attrs": {
            "input_type": "email",
            "value": "ops@example.com",
            "autocomplete": "email",
            "inputmode": "email",
            "enterkeyhint": "next",
            "form": "settings-form",
            "list": "email-suggestions",
            "placeholder": "name@company.com",
            "minlength": 6,
            "maxlength": 64,
            "pattern": ".+@example\\.com",
            "required": true,
            "readonly": true,
            "aria": {
              "invalid": "grammar",
              "autocomplete": "list",
              "active_descendant": "email-suggestion-1",
              "errormessage": "email-error"
            },
            "description": "Use your work email",
            "group": "Account"
          }
        },
        {
          "id": "e_save",
          "role": "button",
          "text": "Save",
          "actions": ["click"],
          "attrs": {
            "accesskey": "s",
            "popovertarget": "save-status",
            "popovertargetaction": "show",
            "commandfor": "save-status",
            "command": "toggle-popover",
            "disabled": true,
            "aria": {
              "keyshortcuts": "Meta+S",
              "roledescription": "primary action",
              "busy": true,
              "live": "polite",
              "atomic": false,
              "relevant": "additions text",
              "owns": "save-menu",
              "flowto": "save-confirmation",
              "details": "save-details"
            },
            "description": "Unavailable until required fields are complete"
          }
        },
        {
          "id": "e_plan",
          "role": "select",
          "label": "Plan",
          "actions": ["select"],
          "attrs": {
            "required": true,
            "value": "team",
            "aria": {
              "expanded": false,
              "controls": "plan-options",
              "haspopup": "listbox"
            },
            "options": [
              { "value": "starter", "text": "Starter" },
              { "value": "team", "text": "Team", "selected": true }
            ],
            "group": "Billing"
          }
        },
        {
          "id": "e_compact",
          "role": "checkbox",
          "label": "Compact mode",
          "actions": ["toggle"],
          "attrs": {
            "checked": false,
            "aria": {
              "pressed": false
            },
            "group": "Preferences"
          }
        },
        {
          "id": "e_annual",
          "role": "radio",
          "label": "Annual billing",
          "actions": ["select"],
          "attrs": {
            "group": "Billing",
            "aria": {
              "checked": true,
              "selected": true
            }
          }
        },
        {
          "id": "e_billing",
          "role": "link",
          "label": "Billing settings",
          "actions": ["click"],
          "attrs": {
            "href": "/billing",
            "aria": {
              "current": "page"
            }
          }
        }
      ]
    }
  ]
}
