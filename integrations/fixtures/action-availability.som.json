{
  "som_version": "1.0",
  "url": "https://example.com/settings",
  "title": "Settings",
  "lang": "en",
  "meta": {
    "html_bytes": 1200,
    "som_bytes": 300,
    "element_count": 10,
    "interactive_count": 10
  },
  "regions": [
    {
      "id": "r_settings",
      "role": "form",
      "label": "Settings form",
      "action": "/settings",
      "method": "POST",
      "target": "_self",
      "enctype": "multipart/form-data",
      "novalidate": true,
      "accept_charset": "UTF-8",
      "autocomplete": "off",
      "elements": [
        {
          "id": "e_email",
          "html_id": "work-email",
          "role": "text_input",
          "label": "Work email",
          "actions": ["type"],
          "attrs": {
            "input_type": "email",
            "name": "email",
            "value": "ops@example.com",
            "autocomplete": "email",
            "inputmode": "email",
            "enterkeyhint": "next",
            "autocapitalize": "none",
            "dirname": "email.dir",
            "dir": "ltr",
            "lang": "en-US",
            "form": "settings-form",
            "list": "email-suggestions",
            "placeholder": "name@company.com",
            "title": "Credential field",
            "aria_label": "Work email",
            "aria_description": "Use your work email",
            "labelledby": "email-label",
            "describedby": "email-help",
            "test_id": "settings-email",
            "data_state": "readonly",
            "spellcheck": false,
            "minlength": 6,
            "maxlength": 64,
            "pattern": ".+@example\\.com",
            "required": true,
            "aria": {
              "readonly": true,
              "multiline": true,
              "placeholder": "Work email address",
              "invalid": "grammar",
              "autocomplete": "list",
              "active_descendant": "email-suggestion-1",
              "errormessage": "email-error"
            },
            "description": "Use your work email",
            "group": "Account"
          }
        },
        {
          "id": "e_upload",
          "role": "text_input",
          "label": "Evidence files",
          "actions": ["type"],
          "attrs": {
            "input_type": "file",
            "name": "evidence",
            "accept": "image/png,.pdf",
            "capture": "environment",
            "multiple": true,
            "required": true,
            "description": "Attach screenshots or PDFs"
          }
        },
        {
          "id": "e_save",
          "html_id": "save-settings",
          "role": "button",
          "text": "Save",
          "actions": ["click"],
          "attrs": {
            "accesskey": "s",
            "popovertarget": "save-status",
            "popovertargetaction": "show",
            "commandfor": "save-status",
            "command": "toggle-popover",
            "button_type": "submit",
            "formaction": "/settings/save",
            "formmethod": "post",
            "formenctype": "application/x-www-form-urlencoded",
            "formtarget": "_top",
            "formnovalidate": true,
            "test_id": "settings-save",
            "data_action": "save-settings",
            "data_state": "blocked",
            "disabled": true,
            "aria": {
              "keyshortcuts": "Meta+S",
              "roledescription": "primary action",
              "busy": true,
              "live": "polite",
              "atomic": false,
              "relevant": "additions text",
              "owns": "save-menu",
              "flowto": "save-confirmation",
              "details": "save-details"
            },
            "description": "Unavailable until required fields are complete"
          }
        },
        {
          "id": "e_preview",
          "role": "button",
          "text": "Preview changes",
          "actions": ["click"],
          "attrs": {
            "inert": true,
            "description": "Preview is unavailable while the form is locked"
          }
        },
        {
          "id": "e_image_submit",
          "role": "button",
          "label": "Upload receipt",
          "actions": ["click"],
          "attrs": {
            "input_type": "image",
            "button_type": "submit",
            "name": "intent",
            "value": "receipt",
            "alt": "Upload receipt",
            "src": "/assets/upload-receipt.svg",
            "description": "Icon-only image submitter"
          }
        },
        {
          "id": "e_plan",
          "role": "select",
          "label": "Plan",
          "actions": ["select"],
          "attrs": {
            "required": true,
            "value": "team",
            "multiple": true,
            "aria": {
              "expanded": false,
              "controls": "plan-options",
              "haspopup": "listbox",
              "multiselectable": true,
              "level": "2",
              "posinset": "1",
              "setsize": "3"
            },
            "options": [
              { "value": "starter", "text": "Starter" },
              { "value": "team", "text": "Team", "selected": true },
              { "value": "enterprise", "text": "Enterprise", "disabled": true, "group": "Growth" },
              { "value": "agency", "text": "Agency", "selected": true, "group": "Growth" }
            ],
            "selected_values": ["team", "agency"],
            "size": 4,
            "group": "Billing"
          }
        },
        {
          "id": "e_compact",
          "role": "checkbox",
          "label": "Compact mode",
          "actions": ["toggle"],
          "attrs": {
            "checked": false,
            "aria": {
              "pressed": false
            },
            "group": "Preferences"
          }
        },
        {
          "id": "e_annual",
          "role": "radio",
          "label": "Annual billing",
          "actions": ["select"],
          "attrs": {
            "group": "Billing",
            "aria": {
              "checked": true,
              "selected": true
            }
          }
        },
        {
          "id": "e_quota",
          "role": "text_input",
          "label": "Seat quota",
          "actions": ["type", "clear"],
          "attrs": {
            "input_type": "range",
            "value": "40",
            "min": 1,
            "max": 100,
            "step": "5",
            "aria": {
              "orientation": "horizontal",
              "valuemin": "1",
              "valuemax": "100",
              "valuenow": "40",
              "valuetext": "40 seats"
            },
            "group": "Billing"
          }
        },
        {
          "id": "e_billing",
          "html_id": "billing-link",
          "role": "link",
          "label": "Billing settings",
          "actions": ["click"],
          "attrs": {
            "href": "/billing",
            "target": "_blank",
            "rel": "noopener",
            "download": "billing.csv",
            "aria": {
              "current": "page"
            }
          }
        }
      ]
    }
  ]
}
