{
  "som_version": "1.0",
  "url": "https://example.com/settings",
  "title": "Settings",
  "lang": "en",
  "meta": {
    "html_bytes": 1200,
    "som_bytes": 300,
    "element_count": 6,
    "interactive_count": 6
  },
  "regions": [
    {
      "id": "r_settings",
      "role": "form",
      "label": "Settings form",
      "elements": [
        {
          "id": "e_email",
          "role": "text_input",
          "label": "Work email",
          "actions": ["type"],
          "attrs": {
            "input_type": "email",
            "value": "ops@example.com",
            "placeholder": "name@company.com",
            "required": true,
            "readonly": true,
            "description": "Use your work email",
            "group": "Account"
          }
        },
        {
          "id": "e_save",
          "role": "button",
          "text": "Save",
          "actions": ["click"],
          "attrs": {
            "disabled": true,
            "description": "Unavailable until required fields are complete"
          }
        },
        {
          "id": "e_plan",
          "role": "select",
          "label": "Plan",
          "actions": ["select"],
          "attrs": {
            "required": true,
            "value": "team",
            "aria": {
              "expanded": false,
              "controls": "plan-options",
              "haspopup": "listbox"
            },
            "options": [
              { "value": "starter", "text": "Starter" },
              { "value": "team", "text": "Team", "selected": true }
            ],
            "group": "Billing"
          }
        },
        {
          "id": "e_compact",
          "role": "checkbox",
          "label": "Compact mode",
          "actions": ["toggle"],
          "attrs": {
            "checked": false,
            "aria": {
              "pressed": false
            },
            "group": "Preferences"
          }
        },
        {
          "id": "e_annual",
          "role": "radio",
          "label": "Annual billing",
          "actions": ["select"],
          "attrs": {
            "group": "Billing",
            "aria": {
              "checked": true,
              "selected": true
            }
          }
        },
        {
          "id": "e_billing",
          "role": "link",
          "label": "Billing settings",
          "actions": ["click"],
          "attrs": {
            "href": "/billing",
            "aria": {
              "current": "page"
            }
          }
        }
      ]
    }
  ]
}
