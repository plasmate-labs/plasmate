{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plasmate.dev/schemas/som/v1.0/som.json",
  "title": "SOM (Semantic Object Model) Document",
  "description": "A structured JSON representation of a web page for LLM and agent consumption. See SOM-SPEC-v1.0.md.",
  "type": "object",
  "required": ["som_version", "url", "title", "lang", "regions", "meta"],
  "additionalProperties": false,
  "properties": {
    "som_version": {
      "type": "string",
      "description": "SOM specification version."
    },
    "url": {
      "type": "string",
      "description": "The URL of the page."
    },
    "title": {
      "type": "string",
      "description": "The page title extracted from <title>."
    },
    "lang": {
      "type": "string",
      "description": "The page language from <html lang>. Defaults to 'en'."
    },
    "regions": {
      "type": "array",
      "description": "Semantic regions extracted from the page body.",
      "items": { "$ref": "#/$defs/Region" }
    },
    "meta": { "$ref": "#/$defs/SomMeta" },
    "structured_data": {
      "$ref": "#/$defs/StructuredData",
      "description": "Structured data extracted from the page (JSON-LD, OpenGraph, Twitter Cards, meta). Omitted if empty."
    }
  },
  "$defs": {
    "SomMeta": {
      "type": "object",
      "description": "Metadata about the SOM compilation.",
      "required": ["html_bytes", "som_bytes", "element_count", "interactive_count"],
      "additionalProperties": false,
      "properties": {
        "html_bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "Size of the source HTML in bytes."
        },
        "som_bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "Size of the serialized SOM JSON in bytes."
        },
        "element_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of elements across all regions."
        },
        "interactive_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of interactive elements."
        }
      }
    },
    "Region": {
      "type": "object",
      "description": "A semantic region within the page.",
      "required": ["id", "role", "elements"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^r_[a-z]+(_[0-9]+)?$",
          "description": "Stable region identifier."
        },
        "role": { "$ref": "#/$defs/RegionRole" },
        "label": {
          "type": "string",
          "description": "Accessible label for the region."
        },
        "action": {
          "type": "string",
          "description": "Form action URL (form regions only)."
        },
        "method": {
          "type": "string",
          "description": "Form method, uppercased (form regions only)."
        },
        "target": {
          "type": "string",
          "description": "Form target browsing context (form regions only)."
        },
        "enctype": {
          "type": "string",
          "description": "Form encoding type (form regions only)."
        },
        "novalidate": {
          "type": "boolean",
          "description": "Whether form validation is disabled before submit."
        },
        "accept_charset": {
          "type": "string",
          "description": "Form accepted character encodings."
        },
        "autocomplete": {
          "type": "string",
          "description": "Form-level autocomplete policy."
        },
        "elements": {
          "type": "array",
          "description": "Semantic elements within this region.",
          "items": { "$ref": "#/$defs/Element" }
        }
      }
    },
    "RegionRole": {
      "type": "string",
      "enum": ["navigation", "main", "aside", "header", "footer", "form", "dialog", "content"],
      "description": "The semantic role of a region."
    },
    "Element": {
      "type": "object",
      "description": "A semantic element within a region.",
      "required": ["id", "role"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable element identifier."
        },
        "html_id": {
          "type": "string",
          "description": "Original HTML id attribute from the source element, for DOM resolution."
        },
        "role": { "$ref": "#/$defs/ElementRole" },
        "text": {
          "type": "string",
          "description": "Visible text content of the element."
        },
        "label": {
          "type": "string",
          "description": "Accessible label, included only when different from text."
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["click", "type", "clear", "select", "toggle"]
          },
          "description": "Available actions for interactive elements."
        },
        "attrs": {
          "type": "object",
          "description": "Role-specific attributes.",
          "properties": {
            "href": { "type": "string" },
            "target": { "type": "string" },
            "rel": { "type": "string" },
            "download": {
              "oneOf": [
                { "type": "boolean" },
                { "type": "string" }
              ]
            },
            "input_type": { "type": "string" },
            "value": { "type": "string" },
            "placeholder": { "type": "string" },
            "required": { "type": "boolean" },
            "readonly": { "type": "boolean" },
            "disabled": { "type": "boolean" },
            "inert": { "type": "boolean" },
            "checked": { "type": "boolean" },
            "group": { "type": "string" },
            "multiple": { "type": "boolean" },
            "options": {
              "type": "array",
              "items": { "$ref": "#/$defs/SelectOption" }
            },
            "selected_values": {
              "type": "array",
              "items": { "type": "string" }
            },
            "size": {
              "oneOf": [
                { "type": "integer" },
                { "type": "string" }
              ]
            },
            "level": {
              "type": "integer",
              "minimum": 1,
              "maximum": 6
            },
            "alt": { "type": "string" },
            "src": { "type": "string" },
            "ordered": { "type": "boolean" },
            "items": {
              "type": "array",
              "items": { "$ref": "#/$defs/ListItem" }
            },
            "headers": {
              "type": "array",
              "items": { "type": "string" }
            },
            "rows": {
              "type": "array",
              "items": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "section_label": { "type": "string" },
            "legend": { "type": "string" },
            "open": { "type": "boolean" },
            "summary": { "type": "string" },
            "contenteditable": {
              "oneOf": [
                { "type": "boolean" },
                { "type": "string" }
              ]
            },
            "tabindex": {
              "oneOf": [
                { "type": "integer" },
                { "type": "string" }
              ]
            },
            "accesskey": { "type": "string" },
            "autofocus": { "type": "boolean" },
            "spellcheck": {
              "oneOf": [
                { "type": "boolean" },
                { "type": "string" }
              ]
            },
            "name": { "type": "string" },
            "test_id": { "type": "string" },
            "test": { "type": "string" },
            "qa": { "type": "string" },
            "cy": { "type": "string" },
            "e2e": { "type": "string" },
            "automation_id": { "type": "string" },
            "accept": { "type": "string" },
            "capture": {
              "oneOf": [
                { "type": "boolean" },
                { "type": "string" }
              ]
            },
            "autocomplete": { "type": "string" },
            "inputmode": { "type": "string" },
            "enterkeyhint": { "type": "string" },
            "autocapitalize": { "type": "string" },
            "dirname": { "type": "string" },
            "form": { "type": "string" },
            "list": { "type": "string" },
            "popovertarget": { "type": "string" },
            "popovertargetaction": { "type": "string" },
            "commandfor": { "type": "string" },
            "command": { "type": "string" },
            "popover": { "type": "string" },
            "button_type": { "type": "string" },
            "formaction": { "type": "string" },
            "formmethod": { "type": "string" },
            "formenctype": { "type": "string" },
            "formtarget": { "type": "string" },
            "formnovalidate": { "type": "boolean" },
            "minlength": {
              "oneOf": [
                { "type": "integer" },
                { "type": "string" }
              ]
            },
            "maxlength": {
              "oneOf": [
                { "type": "integer" },
                { "type": "string" }
              ]
            },
            "min": {
              "oneOf": [
                { "type": "integer" },
                { "type": "string" }
              ]
            },
            "max": {
              "oneOf": [
                { "type": "integer" },
                { "type": "string" }
              ]
            },
            "step": { "type": "string" },
            "pattern": { "type": "string" },
            "description": { "type": "string" },
            "aria": { "$ref": "#/$defs/AriaState" },
            "has_srcdoc": { "type": "boolean" },
            "srcdoc_preview": { "type": "string" },
            "sandbox": { "type": "string" },
            "allow": { "type": "string" },
            "width": { "type": "string" },
            "height": { "type": "string" }
          },
          "additionalProperties": false
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/Element" },
          "description": "Child elements (reserved for future use)."
        },
        "hints": {
          "type": "array",
          "items": { "$ref": "#/$defs/SemanticHint" },
          "description": "Semantic hints inferred from CSS classes."
        },
        "shadow": {
          "$ref": "#/$defs/ShadowRoot",
          "description": "Declarative shadow DOM content attached to this element."
        }
      }
    },
    "ElementRole": {
      "type": "string",
      "enum": [
        "link",
        "button",
        "text_input",
        "textarea",
        "select",
        "checkbox",
        "radio",
        "heading",
        "image",
        "list",
        "table",
        "paragraph",
        "section",
        "group",
        "separator",
        "details",
        "iframe"
      ],
      "description": "The semantic role of an element."
    },
    "AriaState": {
      "type": "object",
      "description": "Common ARIA states copied from the source element.",
      "additionalProperties": false,
      "properties": {
        "expanded": { "type": "boolean" },
        "selected": { "type": "boolean" },
        "checked": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string" }
          ]
        },
        "readonly": { "type": "boolean" },
        "disabled": { "type": "boolean" },
        "current": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string" }
          ]
        },
        "pressed": { "type": "boolean" },
        "hidden": { "type": "boolean" },
        "controls": { "type": "string" },
        "haspopup": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string" }
          ]
        },
        "invalid": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string" }
          ]
        },
        "placeholder": { "type": "string" },
        "autocomplete": { "type": "string" },
        "active_descendant": { "type": "string" },
        "errormessage": { "type": "string" },
        "keyshortcuts": { "type": "string" },
        "roledescription": { "type": "string" },
        "busy": { "type": "boolean" },
        "live": { "type": "string" },
        "atomic": { "type": "boolean" },
        "relevant": { "type": "string" },
        "owns": { "type": "string" },
        "flowto": { "type": "string" },
        "details": { "type": "string" },
        "multiline": { "type": "boolean" },
        "multiselectable": { "type": "boolean" },
        "orientation": { "type": "string" },
        "sort": { "type": "string" },
        "level": { "type": "string" },
        "posinset": { "type": "string" },
        "setsize": { "type": "string" },
        "valuemin": { "type": "string" },
        "valuemax": { "type": "string" },
        "valuenow": { "type": "string" },
        "valuetext": { "type": "string" }
      }
    },
    "ShadowRoot": {
      "type": "object",
      "description": "Elements extracted from a declarative shadow root.",
      "required": ["mode", "elements"],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["open", "closed"]
        },
        "elements": {
          "type": "array",
          "items": { "$ref": "#/$defs/Element" }
        }
      }
    },
    "SemanticHint": {
      "type": "string",
      "enum": [
        "active",
        "badge",
        "card",
        "collapsed",
        "danger",
        "disabled",
        "error",
        "expanded",
        "hero",
        "hidden",
        "large",
        "loading",
        "modal",
        "notification",
        "primary",
        "required",
        "secondary",
        "selected",
        "small",
        "sticky",
        "success",
        "warning"
      ],
      "description": "A semantic hint inferred from CSS class names."
    },
    "SelectOption": {
      "type": "object",
      "required": ["value", "text"],
      "additionalProperties": false,
      "properties": {
        "value": {
          "type": "string",
          "description": "The option value."
        },
        "text": {
          "type": "string",
          "description": "The option display text."
        },
        "selected": {
          "type": "boolean",
          "description": "Whether this option is selected."
        },
        "disabled": {
          "type": "boolean",
          "description": "Whether this option is disabled directly or by a disabled optgroup."
        },
        "group": {
          "type": "string",
          "description": "The parent optgroup label, when present."
        }
      }
    },
    "ListItem": {
      "type": "object",
      "required": ["text"],
      "additionalProperties": false,
      "properties": {
        "text": {
          "type": "string",
          "description": "The list item text."
        }
      }
    },
    "StructuredData": {
      "type": "object",
      "description": "Structured data extracted from the page head.",
      "additionalProperties": false,
      "properties": {
        "json_ld": {
          "type": "array",
          "items": { "type": "object" },
          "description": "JSON-LD blocks (Schema.org data)."
        },
        "open_graph": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "OpenGraph metadata (og:* properties)."
        },
        "twitter_card": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Twitter/X Card metadata (twitter:* names)."
        },
        "meta": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Standard HTML meta tags."
        },
        "links": {
          "type": "array",
          "items": { "$ref": "#/$defs/LinkElement" },
          "description": "Semantically meaningful <link> elements."
        }
      }
    },
    "LinkElement": {
      "type": "object",
      "description": "A <link> element with rel and href.",
      "required": ["rel", "href"],
      "additionalProperties": false,
      "properties": {
        "rel": {
          "type": "string",
          "description": "The rel attribute value (lowercased)."
        },
        "href": {
          "type": "string",
          "description": "The href attribute value."
        },
        "type": {
          "type": "string",
          "description": "The type attribute value."
        },
        "hreflang": {
          "type": "string",
          "description": "The hreflang attribute value."
        }
      }
    }
  }
}
